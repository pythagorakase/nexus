{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NEXUS",
  "version": "0.1.0",
  "identifier": "com.pythagorakase.nexus",
  "build": {
    "frontendDist": "../desktop"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "NEXUS",
        "url": "index.html",
        "width": 1440,
        "height": 960,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "category": "Productivity",
    "shortDescription": "NEXUS native desktop shell",
    "longDescription": "A native shell that launches or attaches to the NEXUS managed runtime and displays the existing web client.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  }
}
