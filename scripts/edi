#!/usr/bin/env python3
"""
EDI Communication CLI (wrapper)

This is a thin wrapper around the EDI-Link client at ~/EDI/packages/client/edi.
See that package for full documentation and features like thread management.

Usage:
    edi "Hello, EDI!"
    edi --new "Start fresh conversation"
    edi --thread abc123 "Continue specific thread"
"""

import os
import sys

# Delegate to the real EDI-Link client
EDI_LINK_CLIENT = os.path.expanduser("~/EDI/packages/client/edi")

if __name__ == "__main__":
    os.execv(EDI_LINK_CLIENT, [EDI_LINK_CLIENT] + sys.argv[1:])
